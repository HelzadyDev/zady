{
  "name": "@helzady/zady",
  "version": "1.2.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "um logger simples e poderoso para Node.js, com saídas formatadas no console, tratamento de erros e utilitários focados no desenvolvedor.",
  "homepage": "https://github.com/HelzadyDev/zady#readme",
  "bugs": {
    "url": "https://github.com/HelzadyDev/zady/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HelzadyDev/zady.git"
  },
  "license": "MIT",
  "author": "HelzadyDev",
  "type": "module",
  "files": [
    "build"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx ./src/index.ts",
    "check": "tsc --noEmit && eslint src --ext .ts && ts-prune",
    "prepublishOnly": "npm run check-build",
    "check-build": "node scripts/check-build.js"
  },
  "keywords": [
    "logger",
    "log",
    "console",
    "nodejs",
    "utils",
    "logging",
    "degub",
    "error",
    "terminal",
    "developer",
    "cli",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "imports": {
    "#functions": [
      "./build/functions/index.js"
    ],
    "#utils": [
      "./build/utils/index.js"
    ],
    "#core": [
      "./build/core/index.js"
    ],
    "#settings": [
      "./build/settings/index.js"
    ]
  }
}
