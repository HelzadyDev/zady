{
    "name": "@zady/core",
    "version": "1.0.0",
    "description": "Coleção de funções utilitárias em TypeScript para acelerar o desenvolvimento de bots Discord — validação de e-mail e URL, formatação e manipulação de texto, geração de números aleatórios e helpers diversos.",
    "keywords": [
        "discord",
        "discord.js",
        "discordjs",
        "discord-bot",
        "bot",
        "utils",
        "utilities",
        "helpers",
        "text-utils",
        "validation",
        "random",
        "typescript"
    ],
    "publishConfig": {
        "access": "public"
    },
    "homepage": "https://github.com/HelzadyDev/zady/tree/main/packages/core#readme",
    "bugs": {
        "url": "https://github.com/HelzadyDev/zady/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/HelzadyDev/zady.git",
        "directory": "packages/core"
    },
    "license": "ISC",
    "author": {
        "url": "https://github.com/HelzadyDev",
        "name": "Helzady"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "unbuild",
        "dev": "tsx playground/index.ts",
        "check-types": "unbuild --noEmit"
    },
    "devDependencies": {
        "@zady/config": "*",
        "tsx": "^4.23.1",
        "unbuild": "^2.0.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.10"
    }
}